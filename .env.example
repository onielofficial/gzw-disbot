# ========= REQUIRED =========
# Discord application token (https://discord.com/developers/applications)
DISCORD_TOKEN=replace-me

# Comma-separated guild IDs for fast slash-command sync during dev.
# Leave empty to sync globally (takes ~1h to propagate).
DEV_GUILD_IDS=

# ========= OPTIONAL =========
# Where to scrape data from. The bot only ever issues GETs to this origin.
GZW_BASE_URL=https://gzwtacmap.com
GZW_MAP_SLUG=lamang

# Cache / data directories (paths relative to project root)
DATA_DIR=./data
CACHE_TTL_HOURS=12

# Refresh schedule: cron-like. Default = every 6 hours
REFRESH_CRON=0 */6 * * *

# How polite to be to gzwtacmap.com
SCRAPE_CONCURRENCY=4
SCRAPE_DELAY_MS=400
USER_AGENT=GZW-DisBot/1.0 (+contact: your-email@example.com)

# Embeds branding
EMBED_FOOTER=GZW Tac DisBot · INTEL gathered from gzwtacmap.com
EMBED_THUMB_URL=

# Logging
LOG_LEVEL=INFO
